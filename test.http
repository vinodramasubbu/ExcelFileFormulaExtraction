### ─── Classify Single Policy – Personal Line ────────────────────
### Replicates: IF(type="Business Policy","No","Yes")

POST {{baseUrl}}/api/policies/classify
Content-Type: application/json

{
  "policy_type": "Automobile"
}

### ─── Classify Single Policy – Business Policy ──────────────────

POST {{baseUrl}}/api/policies/classify
Content-Type: application/json

{
  "policy_type": "Business Policy"
}

### ─── Bulk Policy Classification ────────────────────────────────

POST {{baseUrl}}/api/policies/classify/bulk
Content-Type: application/json

{
  "policies": [
    { "policy_type": "Automobile" },
    { "policy_type": "Business Policy" },
    { "policy_type": "Health" },
    { "policy_type": "Homeowners" },
    { "policy_type": "Life" },
    { "policy_type": "Renters" }
  ]
}
